{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": { "recommended": true }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "json": {
    "formatter": { "enabled": true }
  },
  "files": {
    "includes": [
      "**/*.js",
      "**/*.json",
      "**/*.jsonc",
      "!**/node_modules",
      "!**/.worktrees",
      "!**/bun.lock"
    ]
  }
}
